# Cairn — environment variables
# Copy to .env and edit. None of these are required for local dev;
# the defaults listed here match docker-compose.yml.

# ---------- server ----------
PORT=8787
HOST=0.0.0.0

# ---------- auth (optional, but mandatory once exposed) ----------
# Cairn has NO auth by default (single-user, meant for a trusted private network).
# Set a token to require it on /api and /mcp — MANDATORY if the port is reachable
# beyond localhost (LAN, Tailscale Funnel, a public reverse proxy, a "public" cloud
# sandbox port). The PWA prompts for it once and stores it; MCP/API clients send
# `Authorization: Bearer <token>` or `X-Cairn-Token: <token>`.
# Generate one: `openssl rand -hex 32`
# CAIRN_AUTH_TOKEN=
#
# Fail closed: with this set to 1, Cairn REFUSES to start unless CAIRN_AUTH_TOKEN
# is also set. Bake it into any compose/template that exposes the port so the
# instance can never boot unauthenticated. Leave unset for localhost/tailnet use.
# CAIRN_REQUIRE_AUTH=0
#
# Per-IP rate limit on /api and /mcp (defense-in-depth; active only when a token
# is set). Defaults shown; set CAIRN_RATE_LIMIT=0 to disable even with auth on.
# CAIRN_RATE_LIMIT=600
# CAIRN_RATE_WINDOW_MS=60000

# ---------- storage ----------
# In Docker the /data volume is used automatically (set by the Dockerfile).
# For local dev the default is ./data/cairn.db — no override needed.
# DATA_DIR=/data          # directory that holds cairn.db (Docker default)
# DB_PATH=/data/cairn.db  # explicit full path override (rarely needed)

# ---------- locale ----------
TZ=America/New_York       # IANA timezone — used by the scheduler for coach_hour

# ---------- weekly auto-draft (optional) ----------
# Seed values for the first-run settings row. After first boot these are
# stored in the DB and editable via the Settings tab / set_settings MCP tool.
# COACH_AGENT=           # e.g. claude, codex, auto — leave empty to skip seeding
# COACH_DAY=0            # 0=Sunday … 6=Saturday
# COACH_HOUR=20          # local hour (0-23) in TZ above

# ---------- coaching API keys ----------
# IMPORTANT: claude/codex/antigravity do NOT use an env API key for coaching.
# `claude -p` and `codex exec` authenticate through their CLI's subscription
# OAuth login dir (~/.claude, ~/.codex, ~/.gemini), stored in the cairn-home
# volume — log in once per provider (see README "Coaching agents").
# Only GROK HEADLESS reliably uses an API key:
# XAI_API_KEY=
# These two are passed through for completeness but are not the claude/codex
# coaching path; leave them empty unless you have a specific use for them.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ---------- generated artwork (optional) ----------
# ARTWORK ONLY — this is NOT a coaching agent. Google AI Studio key for
# photoreal food / exercise imagery via the gemini-3.1-flash-image model
# (src/art.ts). Cairn deliberately strips it from the coaching agent subprocess
# env. Images are generated in the background and cached in data/art/; without a
# key the PWA falls back to the built-in SVG illustrations.
# GEMINI_API_KEY=

# ---------- Garmin sync (optional, experimental) ----------
# Pull Garmin Connect activities + daily recovery metrics into source tables.
# Credentials can also be set in the Settings tab instead of here. See docs/GARMIN.md.
# GARMIN_USERNAME=
# GARMIN_PASSWORD=
# GARMIN_TOKEN_DIR=          # where OAuth tokens are cached (defaults under DATA_DIR)
# GARMIN_SYNC_DAYS=14        # how many days back to sync
# GARMIN_SYNC_LIMIT=50       # max activities per sync
# GARMIN_HR_ZONE_LIMIT=20    # max per-activity HR-zone detail calls per sync
# GARMIN_STRENGTH_LIMIT=20   # max strength activities to fetch detected sets for
# GARMIN_SOURCE_LABEL=garmin

# ---------- agent CLI auto-update (optional) ----------
# Off by default. When on, the enabled coaching CLIs are re-installed on a timer.
# This runs vendor installer scripts inside the container — only enable it on a
# trusted local host / tailnet, never on an internet-exposed deployment.
# AGENT_CLI_AUTO_UPDATE=0
# AGENT_CLI_AUTO_UPDATE_INTERVAL_HOURS=168

# ---------- advanced overrides (rarely needed) ----------
# AGENTS_CONFIG=             # path to an alternate agents.json
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
# GEMINI_TEXT_MODEL=gemini-3.1-flash
# ART_IMAGE_COST_USD=0.039   # spend-telemetry estimate per generated image
# ART_TEXT_IN_USD_PER_M=     # spend-telemetry token pricing for the canonicalize call
# ART_TEXT_OUT_USD_PER_M=
# DAYREAD_PRECOMPUTE_HOUR=   # local hour the scheduler precomputes the next day-read
